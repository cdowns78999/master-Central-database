{
    "manifest_version": 3,
    "name": "Spotify Master Production [Slot 8]",
    "version": "1.0",
    "description": "Premium Spotify data extraction with intelligent field mapping and auto-copy.",
    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "scripting",
        "clipboardWrite"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon.png",
            "48": "icons/icon.png",
            "128": "icons/icon.png"
        }
    },
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://artists.spotify.com/*",
                "https://*.tiiny.site/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "https://artists.spotify.com/*",
        "https://www.googleapis.com/*",
        "https://sheets.googleapis.com/*"
    ]
}