{
    "manifest_version": 3,
    "name": "One Click Walk",
    "version": "1.0",
    "description": "Copies the word 'walk' to your clipboard with one click.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "icons": {
        "128": "icon.png"
    },
    "permissions": [
        "clipboardWrite"
    ]
}