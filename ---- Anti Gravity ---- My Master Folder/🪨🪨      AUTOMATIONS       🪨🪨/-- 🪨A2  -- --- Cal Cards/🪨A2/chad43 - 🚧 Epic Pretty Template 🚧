                <span class="link-pill" onclick="openOverlay('overlay-2a')"><span class="pill-dot" style="background:{TILE_2_OVERLAY_A_DOT_COLOR};box-shadow:0 0 8px {TILE_2_OVERLAY_A_DOT_COLOR};"></span>{TILE_2_OVERLAY_A_LABEL}</span>
                <span class="link-pill" onclick="openOverlay('overlay-2b')"><span class="pill-dot" style="background:{TILE_2_OVERLAY_B_DOT_COLOR};box-shadow:0 0 8px {TILE_2_OVERLAY_B_DOT_COLOR};"></span>{TILE_2_OVERLAY_B_LABEL}</span>
                <span class="link-pill" onclick="openOverlay('overlay-2c')"><span class="pill-dot" style="background:{TILE_2_OVERLAY_C_DOT_COLOR};box-shadow:0 0 8px {TILE_2_OVERLAY_C_DOT_COLOR};"></span>{TILE_2_OVERLAY_C_LABEL}</span>
            </div>
        </div>

        <!-- TILE 3 — supports: approve-tag link-pill, overlay-pills -->
        <div class="detail-block detail-slot" data-index="2" id="detail-2">
            <div class="close-btn" onclick="closeDetail(2)">&#10005;</div>
            <div class="detail-header">
                <div class="detail-num">3</div>
                <div class="detail-title">{TILE_3_TITLE}</div>
            </div>
            <div class="sub-items">
                <a class="link-pill" href="{TILE_3_APPROVE_URL}" target="_blank" rel="noopener"><span class="pill-dot" style="background:{TILE_3_APPROVE_DOT_COLOR};box-shadow:0 0 8px {TILE_3_APPROVE_DOT_COLOR};"></span>{TILE_3_APPROVE_LABEL} — <span class="approve-tag">{TILE_3_APPROVE_TAG} ✦</span></a>
                <span class="link-pill" onclick="openOverlay('overlay-3a')"><span class="pill-dot" style="background:{TILE_3_OVERLAY_A_DOT_COLOR};box-shadow:0 0 8px {TILE_3_OVERLAY_A_DOT_COLOR};"></span>{TILE_3_OVERLAY_A_LABEL}</span>
                <span class="link-pill" onclick="openOverlay('overlay-3b')"><span class="pill-dot" style="background:{TILE_3_OVERLAY_B_DOT_COLOR};box-shadow:0 0 8px {TILE_3_OVERLAY_B_DOT_COLOR};"></span>{TILE_3_OVERLAY_B_LABEL}</span>
                <span class="link-pill" onclick="openOverlay('overlay-3c')"><span class="pill-dot" style="background:{TILE_3_OVERLAY_C_DOT_COLOR};box-shadow:0 0 8px {TILE_3_OVERLAY_C_DOT_COLOR};"></span>{TILE_3_OVERLAY_C_LABEL}</span>
            </div>
        </div>

        <!-- TILE 4 — supports: sub-pills -->
        <div class="detail-block detail-slot" data-index="3" id="detail-3">
            <div class="close-btn" onclick="closeDetail(3)">&#10005;</div>
            <div class="detail-header">
                <div class="detail-num">4</div>
