    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ARTIST_NAME} — Ahead Artist Solutions</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=DM+Sans:wght@400;500;700&amp;display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary: #0ea5e9;
            --accent: #6366f1;
            --bg: #f5f1eb;
            --surface: rgba(255, 255, 255, 0.45);
            --text: #0f172a;
            --text-dim: rgba(15, 23, 42, 0.55);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            background: var(--bg);
            min-height: 100vh;
            color: var(--text);
            position: relative;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
            z-index: 0;
        }

        .blob-1 {
            width: 500px;
            height: 500px;
            background: var(--primary);
            top: -120px;
            left: -100px;
            animation: blobPulse1 12s ease-in-out infinite;
        }

        .blob-2 {
            width: 450px;
            height: 450px;
            background: var(--accent);
            bottom: -100px;
            right: -80px;
            animation: blobPulse2 15s ease-in-out infinite;
        }

        @keyframes blobPulse1 {
            0%, 100% { opacity: 0.10; transform: scale(1); }
            50% { opacity: 0.18; transform: scale(1.08); }
        }

        @keyframes blobPulse2 {
            0%, 100% { opacity: 0.08; transform: scale(1); }
            50% { opacity: 0.16; transform: scale(1.1); }
        }

        .page-wrap {
            position: relative;
            z-index: 1;
            max-width: 960px;
            margin: 0 auto;
            padding: 3rem 1.5rem 5rem;
        }

        .dash-title {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 2.2rem;
            text-align: center;
            background: linear-gradient(135deg, var(--primary), var(--accent), var(--primary));
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: titleShimmer 8s ease-in-out infinite;
            margin-bottom: 0.3rem;
        }

        @keyframes titleShimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .section-label {
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 1rem;
        }

        .section-divider {
            height: 1px;
            width: 80%;
            margin: 3rem auto;
            background: linear-gradient(90deg, transparent, var(--text-dim), transparent);
            opacity: 0.3;
        }

        .overview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
        }

        .p-btn {
            position: relative;
            background: var(--surface);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 18px;
            padding: 1.4rem 1.3rem;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            animation: fadeUp 0.5s ease both;
        }

        .p-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 200%;
            height: 100%;
            background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.35) 50%, transparent 100%);
            animation: shimmerFlow 4s linear infinite;
            pointer-events: none;
        }

        @keyframes shimmerFlow {
            0% { transform: translateX(-50%); }
            100% { transform: translateX(50%); }
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .p-btn .glow-dot {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 10px var(--primary);
            animation: glowPulse 3s ease-in-out infinite;
        }

        @keyframes glowPulse {
            0%, 100% { opacity: 0.5; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.3); }
        }

        .p-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.10);
            border-color: rgba(14, 165, 233, 0.3);
        }

        .p-btn.active {
            background: rgba(255, 255, 255, 0.65);
            box-shadow: 0 0 24px rgba(14, 165, 233, 0.18);
        }

        .p-btn .card-title {
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 1.05rem;
            color: var(--text);
            margin-bottom: 0.25rem;
        }

        .p-btn .card-sub {
            font-size: 0.78rem;
            color: var(--text-dim);
        }

        .detail-block {
            background: var(--surface);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 20px;
            padding: 1.8rem;
            margin-bottom: 1.2rem;
            position: relative;
            animation: fadeUp 0.5s ease both;
            transition: background 0.4s ease, box-shadow 0.4s ease;
        }

        .detail-block.highlight {
            background: rgba(255, 255, 255, 0.65);
            box-shadow: 0 0 28px rgba(14, 165, 233, 0.16);
        }

        .detail-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .detail-num {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.95rem;
            flex-shrink: 0;
        }

        .detail-title {
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 1.15rem;
            color: var(--text);
        }

        .close-btn {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(15, 23, 42, 0.04);
            border: 1px solid rgba(15, 23, 42, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            color: var(--text-dim);
            transition: all 0.25s ease;
        }

        .close-btn:hover {
            background: rgba(15, 23, 42, 0.08);
            transform: scale(1.1);
        }

        .sub-items {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sub-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            background: rgba(14, 165, 233, 0.08);
            border-radius: 100px;
            padding: 0.45rem 1rem 0.45rem 0.55rem;
            font-size: 0.82rem;
            color: var(--text);
        }

        .sub-pill .pill-num {
            background: var(--primary);
            color: #fff;
            font-weight: 700;
            font-size: 0.65rem;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .link-pill {
            display: inline-flex;
            align-self: flex-start;
            align-items: center;
            gap: 0.55rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.7) 100%);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-top: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 100px;
            padding: 0.55rem 1.4rem 0.55rem 1rem;
            min-width: 195px;
            font-family: 'DM Sans', system-ui, sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.01em;
            color: var(--text);
            text-decoration: none;
            cursor: pointer;
            box-shadow:
                0 1px 3px rgba(15, 23, 42, 0.08),
                0 4px 8px rgba(15, 23, 42, 0.04),
                inset 0 1px 0 rgba(255, 255, 255, 0.8);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .link-pill::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 200%;
            height: 100%;
            background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.45) 50%, transparent 100%);
            animation: shimmerFlow 4s linear infinite;
            border-radius: 100px;
            pointer-events: none;
        }

        .link-pill::after {
            content: '';
            position: absolute;
            top: 1px;
            left: 10%;
            width: 80%;
            height: 45%;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, transparent 100%);
            border-radius: 100px;
            pointer-events: none;
        }

        .link-pill:hover {
            background: linear-gradient(180deg, rgba(224, 242, 254, 0.95) 0%, rgba(224, 242, 254, 0.7) 100%);
            border-color: rgba(14, 165, 233, 0.25);
            border-top-color: rgba(14, 165, 233, 0.15);
            box-shadow:
                0 2px 6px rgba(14, 165, 233, 0.12),
                0 6px 16px rgba(14, 165, 233, 0.08),
                inset 0 1px 0 rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

        .approve-tag {
            font-family: 'DM Sans', system-ui, sans-serif;
            font-style: italic;
            font-weight: 700;
            font-size: 0.85rem;
            background: linear-gradient(135deg, #b8860b, #e6b422, #f5d442, #e6b422, #b8860b);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: goldShimmer 3s ease-in-out infinite;
        }

        @keyframes goldShimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 100;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .overlay.active { display: flex; }

        .overlay-inner {
            position: relative;
            max-width: 700px;
            width: 100%;
            background: var(--bg);
            border-radius: 20px;
            padding: 1rem;
            box-shadow: 0 20px 60px rgba(15, 23, 42, 0.25);
        }

        .overlay-inner img {
            width: 100%;
            border-radius: 14px;
        }

        .overlay-close {
            position: absolute;
            top: -12px;
            right: -12px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(15, 23, 42, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.9rem;
            color: var(--text);
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.1);
            transition: all 0.2s ease;
            z-index: 101;
        }

        .overlay-close:hover {
            transform: scale(1.1);
            background: #fff;
        }

        .link-pill .pill-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 6px var(--primary);
            flex-shrink: 0;
        }

        @media (max-width: 600px) {
            .overview-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .detail-num {
                width: 34px;
                height: 34px;
                font-size: 0.85rem;
            }

            .page-wrap {
                padding: 2rem 1rem 4rem;
            }
        }
    </style>


    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="page-wrap">
        <div id="top-anchor"></div>
        <div class="dash-title">{ARTIST_NAME}</div>
        <div style="text-align:center;font-size:0.82rem;color:var(--text-dim);margin-bottom:2rem;">Project Dashboard</div>
        <div class="section-label">OVERVIEW</div>
        <div class="overview-grid">
            <div class="p-btn card-slot" data-index="0" onclick="navToDetail(0)">
                <div class="glow-dot"></div>
                <div class="card-title">{TILE_1_TITLE}</div>
                <div class="card-sub">{TILE_1_SUB}</div>
            </div>
            <div class="p-btn card-slot" data-index="1" onclick="navToDetail(1)">
                <div class="glow-dot"></div>
                <div class="card-title">{TILE_2_TITLE}</div>
                <div class="card-sub">{TILE_2_SUB}</div>
            </div>
            <div class="p-btn card-slot" data-index="2" onclick="navToDetail(2)">
                <div class="glow-dot"></div>
                <div class="card-title">{TILE_3_TITLE}</div>
                <div class="card-sub">{TILE_3_SUB}</div>
            </div>
            <div class="p-btn card-slot" data-index="3" onclick="navToDetail(3)">
                <div class="glow-dot"></div>
                <div class="card-title">{TILE_4_TITLE}</div>
                <div class="card-sub">{TILE_4_SUB}</div>
            </div>
        </div>
        <div class="section-divider"></div>
        <div class="section-label">DETAILS</div>

        <!-- TILE 1 — supports: sub-pill, download-row, link-pill -->
        <div class="detail-block detail-slot" data-index="0" id="detail-0">
            <div class="close-btn" onclick="closeDetail(0)">&#10005;</div>
            <div class="detail-header">
                <div class="detail-num">1</div>
                <div class="detail-title">{TILE_1_TITLE}</div>
            </div>
            <div class="sub-items">
                <span class="sub-pill"><span class="pill-num">1a</span>{TILE_1_DETAIL_A}</span>
                <span class="sub-pill"><span class="pill-num">1b</span>{TILE_1_DETAIL_B}</span>
                <!-- DOWNLOAD ROW: sub-pill label + compact blue-hue button -->
                <div style="display:flex;align-items:center;gap:0.6rem;background:rgba(14,165,233,0.08);border-radius:100px;padding:0.3rem 0.4rem 0.3rem 0.55rem;">
                    <span class="pill-num" style="background:#0ea5e9;color:#fff;font-weight:700;font-size:0.65rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">1c</span>
                    <span style="font-size:0.82rem;color:var(--text);">{TILE_1_DOWNLOAD_LABEL}</span>
                    <a class="link-pill" style="background:linear-gradient(180deg,rgba(224,242,254,0.95) 0%,rgba(224,242,254,0.7) 100%);border-color:rgba(14,165,233,0.2);padding:0.32rem 0.9rem 0.32rem 0.7rem;font-size:0.76rem;min-width:auto;gap:0.35rem;border-radius:8px;" href="{TILE_1_DOWNLOAD_URL}" target="_blank" rel="noopener">{TILE_1_DOWNLOAD_BUTTON}<span class="pill-dot" style="background:#0ea5e9;box-shadow:0 0 8px #0ea5e9;"></span>{TILE_1_DOWNLOAD_FILE}</a>
                </div>
                <!-- LINK PILL: regular glass button -->
                <a class="link-pill" href="{TILE_1_LINK_URL}" target="_blank" rel="noopener"><span class="pill-dot" style="background:{TILE_1_LINK_DOT_COLOR};box-shadow:0 0 8px {TILE_1_LINK_DOT_COLOR};"></span>{TILE_1_LINK_LABEL}</a>
            </div>
        </div>

        <!-- TILE 2 — supports: approve-tag link-pill, overlay-pills -->
        <div class="detail-block detail-slot" data-index="1" id="detail-1">
            <div class="close-btn" onclick="closeDetail(1)">&#10005;</div>
            <div class="detail-header">
                <div class="detail-num">2</div>
                <div class="detail-title">{TILE_2_TITLE}</div>
            </div>
            <div class="sub-items">
                <!-- APPROVE-TAG LINK PILL -->
                <a class="link-pill" href="{TILE_2_APPROVE_URL}" target="_blank" rel="noopener"><span class="pill-dot" style="background:{TILE_2_APPROVE_DOT_COLOR};box-shadow:0 0 8px {TILE_2_APPROVE_DOT_COLOR};"></span>{TILE_2_APPROVE_LABEL} — <span class="approve-tag">{TILE_2_APPROVE_TAG} ✦</span></a>
