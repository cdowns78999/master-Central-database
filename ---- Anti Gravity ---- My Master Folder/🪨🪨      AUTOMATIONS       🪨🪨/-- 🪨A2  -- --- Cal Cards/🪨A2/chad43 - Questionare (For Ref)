.detail-block { background: var(--surface); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.5); border-radius: 20px; padding: 1.8rem; margin-bottom: 1.2rem; position: relative; animation: fadeUp 0.5s ease both; transition: background 0.4s ease, box-shadow 0.4s ease; }
.detail-block.highlight { background: rgba(255,255,255,0.65); box-shadow: 0 0 28px rgba(14,165,233,0.16); }
.detail-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
.detail-num { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--accent)); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.95rem; flex-shrink: 0; }
.detail-title { font-family: 'Playfair Display', serif; font-weight: 600; font-size: 1.15rem; color: var(--text); }
.close-btn { position: absolute; top: 14px; right: 14px; width: 36px; height: 36px; border-radius: 50%; background: rgba(15,23,42,0.04); border: 1px solid rgba(15,23,42,0.08); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1rem; color: var(--text-dim); transition: all 0.25s ease; }
.close-btn:hover { background: rgba(15,23,42,0.08); transform: scale(1.1); }
