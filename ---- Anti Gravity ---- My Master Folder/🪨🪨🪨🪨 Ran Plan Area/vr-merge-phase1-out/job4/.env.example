# =============================================================================
# VR LANGUAGE BARRIER — environment variables
# Copy this file to `.env` (in the same folder as server.js) and fill in real
# values. NEVER commit `.env` to git — `.gitignore` already excludes it.
# =============================================================================


# -----------------------------------------------------------------------------
# OPENAI — Whisper (speech-to-text) + GPT-4o (translation) + Realtime API
# -----------------------------------------------------------------------------
# Used by:
#   - server.js  /realtime-token   (mints ephemeral keys for browser WebRTC)
#   - browser    Whisper batch STT (POST /v1/audio/transcriptions)
#   - browser    GPT-4o translation (POST /v1/chat/completions)
#
# Get yours: https://platform.openai.com/api-keys
#   1. Log in (or sign up — $5 free trial credit on new accounts)
#   2. Click "Create new secret key"
#   3. Name it "VR Language Barrier"
#   4. Copy immediately — you won't see it again
#
# Format: starts with `sk-` (legacy) or `sk-proj-` (project-scoped, preferred)
# Cost (April 2026): Whisper $0.006/min, GPT-4o ~$2.50 per 1M input tokens
OPENAI_API_KEY=sk-proj-REPLACE_ME


# -----------------------------------------------------------------------------
# ELEVENLABS — Text-to-Speech (Flash v2.5 model = ~600ms target)
# -----------------------------------------------------------------------------
# Used by:
#   - server.js  /tts  (POST passthrough to api.elevenlabs.io)
#
# Get yours: https://elevenlabs.io/app/settings/api-keys
#   1. Sign up (free tier = 10,000 characters/month, ~10 min of TTS)
#   2. Click profile -> "API Keys" -> "Create API Key"
#   3. Copy the key
#
# Format: 32-char hex string (e.g. `sk_abc123...`)
# Paid tiers: $5/mo Starter (30k chars), $22/mo Creator (100k chars + voice cloning)
ELEVENLABS_API_KEY=REPLACE_ME


# Voice ID for ElevenLabs TTS output. Default below = "Rachel" (English-leaning).
# Browse voices: https://elevenlabs.io/app/voice-library
# For Japanese output, recommended voices: "Sakura" / "Hinata" / clone your own
# Common multilingual default IDs:
#   21m00Tcm4TlvDq8ikWAM = Rachel (EN, calm)
#   pNInz6obpgDQGcFmaJgB = Adam (EN, deep)
#   XB0fDUnXU5powFXDhCwa = Charlotte (EN, soft, multilingual)
ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM


# Model ID for ElevenLabs.
#   eleven_flash_v2_5    = lowest latency (~600ms), 32 languages, recommended
#   eleven_turbo_v2_5    = balance, slightly higher quality, ~800ms
#   eleven_multilingual_v2 = highest quality, ~1.4s latency
# Stick with flash unless quality complaints come in.
ELEVEN_MODEL_ID=eleven_flash_v2_5


# -----------------------------------------------------------------------------
# VRCHAT — Auto-Invite Bot (invite-bot.js)
# -----------------------------------------------------------------------------
# WARNING: Automating VRChat may violate their Terms of Service.
# USE A THROWAWAY ACCOUNT — never your main. Document risk to user.

VRCHAT_USERNAME=throwaway_bot_account
VRCHAT_PASSWORD=REPLACE_ME


# Base32 TOTP secret. Get it when enabling 2FA on the throwaway account:
#   1. VRChat -> Settings -> Account -> Enable Two-Factor Authentication
#   2. When the QR code shows, click "Can't scan?" -> reveals the base32 secret
#   3. Paste it here (no spaces)
#   4. Phase 5 wires this to `otplib.authenticator.generate(secret)` for login
# Leave blank if 2FA is not enabled (not recommended — VRChat may force it).
VRCHAT_2FA_SECRET=


# Group ID for the auto-invite. Find it:
#   1. Open the group page in browser
#   2. URL ends in /group/grp_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   3. Copy the `grp_...` portion
VRCHAT_GROUP_ID=grp_00000000-0000-0000-0000-000000000000


# Friend IDs to watch for offline->online transitions. Comma-separated.
# Find a user ID:
#   1. Open their VRChat profile in browser
#   2. URL ends in /user/usr_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   3. Copy the `usr_...` portion
# Example: VRCHAT_FRIEND_IDS=usr_111...,usr_222...,usr_333...
VRCHAT_FRIEND_IDS=


# Optional contact email — VRChat API ToU asks for one in the User-Agent header
VRCHAT_CONTACT_EMAIL=you@example.com


# -----------------------------------------------------------------------------
# SERVER CONFIG
# -----------------------------------------------------------------------------
# Port for Express server (server.js). Default 3000. Change if conflicting.
SERVER_PORT=3000


# Default target language for translation. Two-letter ISO 639-1 codes.
#   ja = Japanese (most common use case)
#   en = English
#   ko = Korean
#   zh = Chinese (Mandarin)
#   es = Spanish
#   pt = Portuguese
#   fr = French
#   de = German
DEFAULT_TARGET_LANG=ja


# -----------------------------------------------------------------------------
# OPTIONAL — feature flags
# -----------------------------------------------------------------------------
# Switch the STT path. `realtime` = OpenAI Realtime WebSocket (lower latency,
# higher cost). `whisper-batch` = chunked POST to Whisper (cheaper, ~400ms).
STT_MODE=whisper-batch


# Set to `true` once invite-bot has been audited + ToS warning shown.
# Phase 5 hardening flips this on.
INVITE_BOT_ENABLED=false
