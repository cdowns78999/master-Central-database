# VR Bridge — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Voice translator (server.js) ------------------------------------------
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# --- Auto-invite bot (invite-bot.js) ---------------------------------------
# USE A THROWAWAY ACCOUNT. Automated use of VRChat violates their ToS.
VRCHAT_USERNAME=
VRCHAT_PASSWORD=
VRCHAT_GROUP_ID=
WATCH_FRIEND_IDS=

# Optional — stuffed into the User-Agent (VRChat API ToU expects a contact address)
VRCHAT_CONTACT_EMAIL=

# Optional — base32 TOTP secret if the VRChat account has 2FA enabled
VRCHAT_TOTP_SECRET=

# Optional — override server port (default 3000)
PORT=3000
