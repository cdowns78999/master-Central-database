{
  "manifest_version": 3,
  "name": "WP Article Dropper",
  "version": "1.0",
  "description": "Capture article HTML from the emulator and drop it into WordPress",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.svg",
      "48": "icon48.svg",
      "128": "icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*/wp-admin/post-new.php*", "*://*/*/wp-admin/post.php*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  }
}
