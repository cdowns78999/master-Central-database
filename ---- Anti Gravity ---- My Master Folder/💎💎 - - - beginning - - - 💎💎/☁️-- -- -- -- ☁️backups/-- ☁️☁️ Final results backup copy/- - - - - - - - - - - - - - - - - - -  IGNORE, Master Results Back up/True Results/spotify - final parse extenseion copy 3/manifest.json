{
  "manifest_version": 3,
  "name": "Spotify Parsing Job [ORIGINAL]",
  "version": "1.0",
  "description": "Premium automated screenshot capture and GDrive upload for Spotify analytics.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "identity",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "host_permissions": [
    "<all_urls>",
    "https://*.tiiny.site/*",
    "https://artists.spotify.com/*",
    "https://www.googleapis.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tiiny.site/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "oauth2": {
    "client_id": "908389111255-p7s6bl6lcf2asfri7q6pq059jbce3of4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/spreadsheets.readonly"
    ]
  }
}