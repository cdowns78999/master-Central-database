{
  "manifest_version": 3,
  "name": "Step hotkey",
  "version": "1.0.1",
  "description": "Premium prompt executor - Whole fields",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Step hotkey",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}