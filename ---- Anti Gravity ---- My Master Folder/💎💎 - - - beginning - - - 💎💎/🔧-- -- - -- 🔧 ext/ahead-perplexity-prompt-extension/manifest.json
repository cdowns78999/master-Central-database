{
  "manifest_version": 3,
  "name": "Ahead Prompt Dropper",
  "version": "1.0",
  "description": "Pre-made prompts for Perplexity — copy and drop",
  "permissions": ["clipboardWrite", "activeTab", "storage"],
  "host_permissions": ["https://www.perplexity.ai/*", "https://docs.google.com/*", "https://drive.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.perplexity.ai/*", "https://docs.google.com/*", "https://drive.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Ahead Prompt Dropper"
  }
}
