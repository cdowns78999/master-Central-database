{
  "manifest_version": 3,
  "name": "Pass Off Claude Max Extension 1",
  "version": "1.2",
  "description": "Grabs billing fields from clipboard and gives you one-click copy for each PayPal form field.",
  "permissions": ["clipboardRead", "clipboardWrite", "activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.paypal.com/*",
    "file:///*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.paypal.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
