{
  "manifest_version": 3,
  "name": "Pass Off Claude Max Extension 4 — Cash App",
  "version": "1.1",
  "description": "Grabs billing fields from clipboard and gives you one-click copy for each Cash App form field.",
  "permissions": ["clipboardRead", "clipboardWrite", "activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://cash.app/*",
    "file:///*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://cash.app/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
