{
    "manifest_version": 3,
    "name": "Execution Prompt Copier",
    "version": "1.0",
    "description": "Automatically copies the execution-focused agent prompt to clipboard.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "permissions": [
        "clipboardWrite"
    ],
    "icons": {
        "128": "icon.png"
    }
}