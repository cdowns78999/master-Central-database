{
    "manifest_version": 3,
    "name": "Evolution Suite Master",
    "version": "14.0",
    "description": "Unified Command Center: Workflow Gen, Page Sync, Tone Refine, & Step Tracker.",
    "permissions": [
        "clipboardWrite",
        "scripting",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "icons": {
        "128": "icon.png"
    }
}